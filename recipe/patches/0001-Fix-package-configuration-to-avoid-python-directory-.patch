From 1e7801bc13c2773938b12cdd8e6a8979d79aa55c Mon Sep 17 00:00:00 2001
From: Steven <scrass@anaconda.com>
Date: Tue, 29 Jul 2025 14:47:50 -0600
Subject: [PATCH] Fix package configuration to avoid 'python' directory naming
 conflict

The original setup.py uses find_packages() which discovers the top-level
'python' directory and tries to install it as a package named "python".
This conflicts with the build system trying to create a "python" directory
for the package build process.

This patch fixes the issue by:
1. Explicitly specifying packages=['array_record'] instead of find_packages()
2. Using package_dir={'array_record': 'python'} to map the package to the
   correct source directory
3. Updating package_data to use the correct package name

This allows the package to build correctly without directory naming conflicts.
---
 setup.py | 5 +++--
 1 file changed, 3 insertions(+), 2 deletions(-)

diff --git a/setup.py b/setup.py
index 79990c7..9728bdd 100644
--- a/setup.py
+++ b/setup.py
@@ -29,9 +29,10 @@ setup(
     description='A file format that achieves a new frontier of IO efficiency',
     author='ArrayRecord team',
     author_email='no-reply@google.com',
-    packages=find_packages(),
+    packages=['array_record'],
+    package_dir={'array_record': 'python'},
     include_package_data=True,
-    package_data={'': ['*.so']},
+    package_data={'array_record': ['*.so']},
     python_requires='>=3.10',
     install_requires=REQUIRED_PACKAGES,
     extras_require={'beam': BEAM_EXTRAS},
-- 
